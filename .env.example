# Neon serverless Postgres — use the POOLED connection string (…-pooler.…neon.tech)
# Interactive transactions (the credit ledger) need the WebSocket Pool driver.
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"

# Integration mode for the mockable adapters: "mock" | "live".
# v1 ships only the mocks; the factories (lib/line/index.ts, lib/payments/index.ts)
# FAIL CLOSED — unset/"mock" → mock impl; any other value (e.g. "live") THROWS at
# construction until a real provider is wired, so production can never silently run
# on the always-paid PromptPay mock and grant credits for unpaid charges.
LINE_MODE="mock"
PAYMENTS_MODE="mock"
# Slip-image store for PromptPay verification (lib/storage). unset/"mock" → the mock
# that persists the slip as a base64 data-URL in the DB; "blob" → Vercel Blob (slip
# bytes live in Blob, not the DB; needs BLOB_READ_WRITE_TOKEN). Any other value THROWS
# (fail closed). Swapping stores is a one-line change here.
STORAGE_MODE="mock"
# Vercel Blob token — ONLY needed when STORAGE_MODE=blob. On Vercel this is auto-injected
# when you create a Blob store; set it manually only for local "blob" testing.
# BLOB_READ_WRITE_TOKEN=

# LINE (only needed when LINE_MODE=live)
LINE_CHANNEL_ACCESS_TOKEN=""
LINE_CHANNEL_SECRET=""
LIFF_ID=""

# Admin auth gate (lib/auth/admin.ts). v1 ships a mock provider that always grants
# an admin session. Set ADMIN_AUTH=deny to force the rejection path (locked-down
# staging / tests). Leave unset for v1 dev. Swap in a real staff/LINE provider here
# before exposing the admin app publicly.
ADMIN_AUTH=""

# Admin ROLE for the mock provider: unset/"owner" → full admin; "instructor" →
# Today scoped to their own classes + roster check-in only (everything else is
# Owner-only). When instructor, ADMIN_INSTRUCTOR_ID is the instructors.id slug the
# session links to (defaults to "mai"). Real staff auth supplies the role later.
ADMIN_ROLE=""
ADMIN_INSTRUCTOR_ID=""

# Shared secret for the waitlist expiry/cascade cron (/api/cron/waitlist-sweep).
# The route fails closed (503) when unset. In prod, wire a scheduler to call it with
# this secret as `Authorization: Bearer <secret>`. vercel.json already schedules it
# every 5 min — set CRON_SECRET in the Vercel project and Vercel Cron sends the
# Bearer header automatically. The hold is 30 min and reads lazily self-expire, so
# a brief scheduler outage is self-healing.
CRON_SECRET=""
